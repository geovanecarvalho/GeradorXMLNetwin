uploads/
temp_uploads/

# Pasta de Assets (imagens, ícones - commitar apenas os originais)
# Assets/  (não ignore se for commitar os ícones)

# Configuração local do usuário (contém paths específicos)
# config.json - mantém ignorado pois contém paths do usuário
**/config.json
.gerador_de_xml_netwin/

# Perfil do usuário
%USERPROFILE%/.gerador_de_xml_netwin/

